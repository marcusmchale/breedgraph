# Neo4j Configuration
# Although you can't have multiple db in community edition
# you might consider using the plugin from https://dozerdb.org/
# particularly for testing etc.

# or "development"
ENVIRONMENT="production"
# Alternatively you can just change the db name here and in the neo4j conf and restart when you are doing testing
DATABASE_NAME="neo4j"
NEO4J_USERNAME="USERNAME_HERE"
NEO4J_PASSWORD="PASSWORD_HERE"

# Mail host configuration
MAIL_HOST='gmail.com'
MAIL_PORT=465
MAIL_USERNAME="USERNAME_HERE"
MAIL_PASSWORD="PASSWORD_HERE"
MAIL_USE_TLS=1

# Log files
LOG_BASE="/path/to/logs"
BREEDGRAPH_LOG="breedgraph.log"
ARIADNE_LOG="ariadne.log"
NEO4J_LOG="neo4j.log"
REDIS_LOG="redis.log"

# Secret keys
SECRET_KEY='have-a-crack-at-it'
VERIFY_TOKEN_SALT="slip-that-over-your-laughing-gear"
 # in minutes
VERIFY_EXPIRES=1440
PASSWORD_RESET_SALT="ZOMFG-How-COULD-y0u-FORGETZ"
 # in minutes
PASSWORD_RESET_EXPIRES=60
LOGIN_SALT="Since-you-asked-so-nicely"
 # in minutes
LOGIN_EXPIRES=10080
CSRF_SALT='tell-me-who-is-asking'
CSRF_EXPIRES=3600

# Hosting environment
PROTOCOL="http"
SITE_NAME='BreedGraph'
HOST_ADDRESS='localhost'
HOST_PORT=8000
GQL_API_PATH='graphql'
VUE_PORT=8080

# Files
FILE_STORAGE_PATH="./file_store"
FILE_DOWNLOAD_SALT="PROVIDE_SALT_FOR_DOWNLOAD_LINKS"
FILE_DOWNLOAD_EXPIRES=1440
MAX_CONCURRENT_UPLOADS=5